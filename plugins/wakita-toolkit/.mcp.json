{
  "mcpServers": {
    "zai-web-search": {
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer ${ZAI_MCP_TOKEN}"
      }
    },
    "zai-web-page-reading": {
      "type": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "Bearer ${ZAI_MCP_TOKEN}"
      }
    },
    "zai-visual-understanding": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@z_ai/mcp-server"],
      "env": {
        "Z_AI_API_KEY": "${ZAI_MCP_TOKEN}",
        "Z_AI_MODE": "ZHIPU"
      }
    }
  }
}
